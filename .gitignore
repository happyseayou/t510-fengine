# OS/editor noise
.DS_Store
Thumbs.db
*~
*.swp
*.swo

# Python/Jupyter caches
__pycache__/
*.py[cod]
.ipynb_checkpoints/

# Vivado/XSim generated state
/.Xil/
/.xsim_batch/
/.vmcp/
/demo-ant.cache/
/demo-ant.gen/
/demo-ant.hw/
/demo-ant.ip_user_files/
/demo-ant.runs/
/demo-ant.sim/

# Vivado source mirror: keep only the checked-in IP config needed by setup flow.
/demo-ant.srcs/*
!/demo-ant.srcs/sources_1/
/demo-ant.srcs/sources_1/*
!/demo-ant.srcs/sources_1/ip/
/demo-ant.srcs/sources_1/ip/*
!/demo-ant.srcs/sources_1/ip/t510_debug_xfft/
/demo-ant.srcs/sources_1/ip/t510_debug_xfft/*
!/demo-ant.srcs/sources_1/ip/t510_debug_xfft/t510_debug_xfft.xci

# Exported overlays are generated by scripts/export_overlay.tcl.
/overlay/

# Build/runtime artifacts
rust/**/target/
*.bit
*.dcp
*.jou
*.log
*.rpt
*.rpx
*.str
*.wdb
*.wcfg
hs_err_pid*.log

# Top-level hardware run captures
/stage*.json
/stage*_stderr.txt
/stage*_stdout.txt

# Large runtime report captures; keep reports/stages and reports/arch docs.
/reports/*.json
/reports/*.log
/reports/*.stdout.json
/reports/*.stdout.log
/reports/*.stderr.log
/reports/board/
